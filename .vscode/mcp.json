{
  "servers": {
    // ── GitHub API MCP ──────────────────────────────────────────────────────
    // Provides: list/read issues, PRs, releases, GHCR manifests, push branches
    // Requires: GITHUB_TOKEN env var (see docs/MANUAL_TOOLCHAIN_ACTIONS.md)
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${env:GITHUB_TOKEN}"
      }
    },

    // ── Local Filesystem MCP ────────────────────────────────────────────────
    // Allows agents to read/write files inside the workspace root only.
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${workspaceFolder}"
      ]
    },

    // ── Redis Inspector MCP ─────────────────────────────────────────────────
    // Read-only inspection of the Redis broker / channel-layer state.
    // Start the dev stack first: docker compose -f docker-compose.dev.yml up -d
    "redis": {
      "command": "npx",
      "args": ["-y", "mcp-server-redis"],
      "env": {
        "REDIS_URL": "redis://localhost:6379"
      }
    },

    // ── Playwright Browser MCP ──────────────────────────────────────────────
    // Headless browser automation for frontend integration testing.
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    }
  }
}
