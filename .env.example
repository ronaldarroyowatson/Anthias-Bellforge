# ─────────────────────────────────────────────────────────────────────────────
# Anthias-Bellforge — Environment Variable Template
# Copy this file to .env and fill in values marked with <REPLACE>.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
# Set in production; auto-generated into ~/.anthias/anthias.conf on first run.
# Required for any direct manage.py usage outside Docker.
DJANGO_SECRET_KEY=<REPLACE: run `python -c "import secrets; print(secrets.token_urlsafe(50))"` >

# development | production | test
ENVIRONMENT=development

# ── Celery / Redis ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Service addresses (override for non-Docker local dev) ─────────────────────
# Hostname that anthias-server binds on
LISTEN=0.0.0.0

# HOME for anthias data directory (~/.anthias/anthias.db etc.)
HOME=/data

# ── GitHub (required for MCP server + update-check in lib/github.py) ─────────
# Create at: https://github.com/settings/tokens
# Required scopes: repo (read), packages:read (for GHCR manifests)
GITHUB_TOKEN=<REPLACE>

# ── Balena Cloud (required for fleet deployment) ──────────────────────────────
# Obtained via: balena login  (stores in ~/.balenarc.yml)
# Export here if you need non-interactive CI pushes.
BALENA_TOKEN=<REPLACE>

# ── Telemetry override (school fork — disable upstream GA if desired) ─────────
# Set to "false" to suppress Google Analytics telemetry events.
# Defaulted to false for Anthias-Bellforge (school fork) — COPPA/FERPA compliance.
TELEMETRY_ENABLED=false

# ── Device type (used by Ansible install playbook) ───────────────────────────
# Allowed values: pi2 | pi3 | pi4-64 | pi5 | x86
DEVICE_TYPE=x86

# ── Docker image tag (used by install.sh and upgrade scripts) ─────────────────
DOCKER_TAG=latest

# ── Anthias git branch to install from (used by install.sh) ──────────────────
ANTHIAS_BRANCH=master
