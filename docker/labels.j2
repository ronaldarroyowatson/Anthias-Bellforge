{# OCI image labels (https://specs.opencontainers.org/image-spec/annotations/).
   `image.source` is the load-bearing one for GitHub Container Registry:
   GHCR uses it to link the package to its source repo, which makes the
   package inherit the repo's visibility and grants repo collaborators
   push/delete access. Without it, packages stay private even when the
   repo is public, and the package page on GitHub has no link back. #}
{% set service_descriptions = {
    'server': 'Bellforge web server (uvicorn + Django + Channels); based on Anthias by Screenly, Inc.',
    'redis': 'Redis broker for Bellforge Celery and Channels',
    'viewer': 'Bellforge display/viewer service',
    'test': 'Bellforge test runner',
} %}
LABEL org.opencontainers.image.source="https://github.com/ronaldwatson/Anthias-Bellforge"
LABEL org.opencontainers.image.url="https://github.com/ronaldwatson/Anthias-Bellforge"
LABEL org.opencontainers.image.licenses="GPL-2.0"
LABEL org.opencontainers.image.title="bellforge-{{ service }}"
LABEL org.opencontainers.image.description="{{ service_descriptions.get(service, 'Bellforge ' + service) }}"
